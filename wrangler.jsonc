{
  "name": "qr-redirect",
  "main": "src/index.js",
  "compatibility_date": "2026-06-09",
  "kv_namespaces": [
    {
      "binding": "REDIRECTS",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "qr-redirect-stats",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}